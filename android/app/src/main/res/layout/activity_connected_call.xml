<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Remote Video (Video calls - fullscreen background) -->
    <FrameLayout
        android:id="@+id/remote_video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#000000" />

    <!-- Local Video (Video calls - small PiP in corner) -->
    <FrameLayout
        android:id="@+id/local_video_container"
        android:layout_width="110dp"
        android:layout_height="160dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="20dp"
        android:visibility="gone"
        android:background="#222222"
        android:elevation="10dp" />

    <!-- Voice Call Content (avatar + name + timer - centered) -->
    <LinearLayout
        android:id="@+id/voice_call_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Circular Avatar -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="24dp"
            android:padding="3dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#334155">

            <ImageView
                android:id="@+id/iv_connected_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/sym_def_app_icon" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_connected_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Caller Name"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="10" />

        <TextView
            android:id="@+id/tv_call_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="0:00"
            android:textColor="#B3FFFFFF"
            android:textSize="16sp"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- Video Call Header Pill (shown during video calls over remote video) -->
    <LinearLayout
        android:id="@+id/video_call_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:background="@drawable/bg_header_pill"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:visibility="gone"
        android:elevation="20dp">

        <TextView
            android:id="@+id/tv_video_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_video_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="60dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Mute -->
        <ImageButton
            android:id="@+id/btn_mute"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#1AFFFFFF"
            android:src="@drawable/ic_mic"
            android:scaleType="centerInside"
            android:padding="18dp"
            android:contentDescription="Mute" />

        <!-- Speaker (voice only) -->
        <ImageButton
            android:id="@+id/btn_speaker"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#1AFFFFFF"
            android:src="@drawable/ic_speaker"
            android:scaleType="centerInside"
            android:padding="18dp"
            android:contentDescription="Speaker" />

        <!-- End Call -->
        <ImageButton
            android:id="@+id/btn_end_call"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#FF4757"
            android:src="@drawable/ic_call_decline"
            android:scaleType="centerInside"
            android:padding="20dp"
            android:contentDescription="End Call" />

        <!-- Video Toggle (video only) -->
        <ImageButton
            android:id="@+id/btn_video_toggle"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#1AFFFFFF"
            android:src="@drawable/ic_video"
            android:scaleType="centerInside"
            android:padding="18dp"
            android:visibility="gone"
            android:contentDescription="Toggle Video" />
    </LinearLayout>

</RelativeLayout>
