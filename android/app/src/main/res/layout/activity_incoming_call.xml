<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_call_gradient"
    android:padding="24dp">

    <!-- Top Caller Information (Header Block) -->
    <LinearLayout
        android:id="@+id/ll_caller_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginTop="80dp"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Circular Avatar Container with border -->
        <FrameLayout
            android:layout_width="132dp"
            android:layout_height="132dp"
            android:layout_marginBottom="28dp"
            android:padding="6dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#2D3748">

            <ImageView
                android:id="@+id/iv_caller_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/sym_def_app_icon" />
        </FrameLayout>

        <!-- Caller Name -->
        <TextView
            android:id="@+id/tv_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Incoming Caller"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="10" />

        <!-- Call Status / Type Label -->
        <TextView
            android:id="@+id/tv_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="INCOMING VOICE CALL..."
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:letterSpacing="0.1" />

        <!-- Call Type label (invisible/unused but kept for code compatibility) -->
        <TextView
            android:id="@+id/tv_call_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Bottom Action Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="80dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="2">

        <!-- Decline Button Area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_decline"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="#EF4444"
                android:src="@drawable/ic_call_decline"
                android:scaleType="centerInside"
                android:padding="20dp"
                android:contentDescription="Decline Call" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Decline"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Accept Button Area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_accept"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="#10B981"
                android:src="@drawable/ic_call_accept"
                android:scaleType="centerInside"
                android:padding="20dp"
                android:contentDescription="Accept Call" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Accept"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
